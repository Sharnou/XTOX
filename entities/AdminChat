{
  "name": "AdminChat",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "User who sent/received the message"
    },
    "sender": {
      "type": "string",
      "enum": [
        "user",
        "admin"
      ],
      "description": "Who sent this message"
    },
    "content": {
      "type": "string",
      "description": "Message content"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "user_email",
    "sender",
    "content"
  ]
}